{
    "name": "cable8mm/mma-scrappers",
    "description": "This is the statistics scrappers for MMA",
    "type": "library",
    "keywords": [
        "scrapper",
        "mma",
        "blackcombat",
        "ufc",
        "roadfc"
    ],
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Sam Lee",
            "email": "cable8mm@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "Cable8mm\\MmaScrappers\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "lint": [
        "pint --parallel"
    ],
    "test:lint": [
        "pint --parallel --test"
    ],
    "test": [
        "@php vendor/bin/phpunit"
    ]
}
