{
    "name": "cable8mm/mma-scrapers",
    "description": "MMA scraper library for UFC, Road FC, and Black Combat.",
    "type": "library",
    "keywords": [
        "scraper",
        "mma",
        "blackcombat",
        "ufc",
        "roadfc"
    ],
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Sam Lee",
            "email": "cable8mm@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "guzzlehttp/guzzle": "^7.10",
        "symfony/dom-crawler": "^8.0",
        "symfony/css-selector": "^8.0"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "Cable8mm\\MmaScrapers\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "lint": [
            "pint --parallel"
        ],
        "test": [
            "vendor/bin/phpunit"
        ]
    }
}
